# AlphaForge — Environment Configuration
# Copy this file to .env and fill in your values.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported providers: anthropic | openai | groq | gemini
LLM_PROVIDER=groq

# Model name
# Groq (free):      llama-3.3-70b-versatile
# Anthropic:        claude-3-5-haiku-20241022
# OpenAI:           gpt-4o
# Gemini (free):    gemini-1.5-flash
LLM_MODEL=llama-3.3-70b-versatile

# Your LLM API key — NEVER commit this to git
# Groq (free):   https://console.groq.com/keys
# Anthropic:     https://console.anthropic.com
# OpenAI:        https://platform.openai.com/api-keys
# Gemini (free): https://aistudio.google.com/app/apikey
LLM_API_KEY=your-llm-api-key-here

# Sampling temperature (0.7–1.0 recommended for creative alpha research)
LLM_TEMPERATURE=0.8

# Max tokens per LLM response (3000 recommended for v2 8-section format)
LLM_MAX_TOKENS=3000

# Max generation cycles per session
MAX_CYCLES=20

# Max mutation attempts per alpha before forced ideation restart
MAX_MUTATIONS=4

# Directory for session JSON files
SESSION_DIR=./sessions

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ── WorldQuant BRAIN API ──────────────────────────────────────────────────────
# Required to automatically submit generated alphas for real simulation.
# Use the same email and password you use to log in at worldquantbrain.com
#
# How to get access:
#   1. Register at https://www.worldquantbrain.com
#   2. Complete the IQC 2026 onboarding
#   3. Enter your login credentials below
#
# Set BRAIN_SUBMIT_ENABLED=true to activate the submission pipeline.
# When enabled, every alpha that passes local IQC gates is automatically:
#   - Submitted to BRAIN for simulation
#   - Polled until results are ready (~60-180s per simulation)
#   - Checked against real Sharpe, Fitness, and Turnover gates
#   - Fed back into the LLM mutation loop if real gates fail
#
BRAIN_EMAIL=your-brain-email@example.com
BRAIN_PASSWORD=your-brain-password

# Set to true to enable auto-submission after local validation
BRAIN_SUBMIT_ENABLED=false

# Max seconds to wait for a BRAIN simulation to complete
BRAIN_POLL_TIMEOUT=300
